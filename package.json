{
  "name": "ai-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalogs": {
    "backend": {
      "convex": "^1.37.0",
      "convex-helpers": "^0.1.116"
    },
    "shared": {
      "@ai-sdk/deepseek": "^2.0.34",
      "@ai-sdk/devtools": "^0.0.17",
      "@ai-sdk/google": "^3.0.67",
      "@ai-sdk/moonshotai": "^2.0.22",
      "@ai-sdk/openai": "^3.0.63",
      "@ai-sdk/openai-compatible": "^2.0.47",
      "@axiomhq/js": "^1.6.1",
      "@axiomhq/logging": "^0.2.1",
      "better-result": "^2.9.2",
      "@t3-oss/env-core": "^0.13.11",
      "@workos/authkit-session": "^0.3.4",
      "@workos-inc/node": "^8.13.0",
      "ai": "^6.0.175",
      "dedent": "^1.7.2",
      "jose": "^6.2.3",
      "zod": "^4.4.3"
    },
    "tooling": {
      "@types/bun": "1.3.13",
      "@types/node": "25.6.2",
      "@typescript/native-preview": "7.0.0-dev.20260511.1",
      "oxlint": "^1.63.0",
      "oxlint-tsgolint": "^0.22.1",
      "typescript": "^6.0.3"
    }
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:convex": "bun run --cwd packages/backend dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "check": "bun lint && bun typecheck",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "turbo run lint",
    "lint:fix": "bun run --filter '*' lint:fix",
    "preview": "turbo run preview",
    "typecheck": "turbo run typecheck",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@vercel/config": "^0.3.0"
  },
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.1.4",
    "@typescript/native-preview": "catalog:tooling",
    "oxlint": "catalog:tooling",
    "oxlint-tsgolint": "catalog:tooling",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.12",
    "typescript": "catalog:tooling"
  },
  "trustedDependencies": []
}
